# Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
GEMINI_API_KEY=여기에_발급받은_키_입력

# 선택: Google Analytics 4 (예: G-XXXXXXXXXX)
# GA_MEASUREMENT_ID=

# 선택: Google AdSense (예: ca-pub-XXXXXXXXXXXXXXXX)
# ADSENSE_CLIENT_ID=

# 선택: SEO canonical URL (배포 도메인, 예: https://lawform.example.com)
# CANONICAL_URL=
